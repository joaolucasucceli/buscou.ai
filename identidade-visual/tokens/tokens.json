{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "radius": {
    "xs":   { "value": "4px",   "type": "dimension" },
    "sm":   { "value": "6px",   "type": "dimension" },
    "md":   { "value": "10px",  "type": "dimension", "description": "Padrao de cards e inputs." },
    "lg":   { "value": "18px",  "type": "dimension" },
    "xl":   { "value": "28px",  "type": "dimension" },
    "pill": { "value": "100px", "type": "dimension", "description": "Botoes, badges, search bar." }
  },
  "spacing": {
    "0":   { "value": "0px",    "type": "dimension" },
    "1":   { "value": "4px",    "type": "dimension" },
    "2":   { "value": "8px",    "type": "dimension" },
    "3":   { "value": "12px",   "type": "dimension" },
    "4":   { "value": "16px",   "type": "dimension", "description": "Base de spacing." },
    "5":   { "value": "24px",   "type": "dimension" },
    "6":   { "value": "32px",   "type": "dimension" },
    "7":   { "value": "48px",   "type": "dimension" },
    "8":   { "value": "64px",   "type": "dimension" },
    "9":   { "value": "96px",   "type": "dimension" },
    "10":  { "value": "140px",  "type": "dimension" }
  },
  "shadow": {
    "sm":    { "value": "0 1px 2px rgba(0,0,0,0.3)",                                                    "type": "shadow" },
    "md":    { "value": "0 8px 24px rgba(0,0,0,0.35)",                                                  "type": "shadow" },
    "lg":    { "value": "0 20px 60px rgba(0,0,0,0.45)",                                                 "type": "shadow" },
    "glow":  { "value": "0 0 16px rgba(0,229,160,0.45), 0 0 40px rgba(0,229,160,0.2)",                  "type": "shadow", "description": "Glow do .ai e do cursor." },
    "brand": { "value": "0 0 24px rgba(124,92,255,0.35)",                                               "type": "shadow" }
  },
  "transition": {
    "fast":   { "value": "120ms cubic-bezier(0.2, 0, 0, 1)", "type": "transition" },
    "base":   { "value": "200ms cubic-bezier(0.2, 0, 0, 1)", "type": "transition" },
    "slow":   { "value": "360ms cubic-bezier(0.2, 0, 0, 1)", "type": "transition" },
    "spring": { "value": "600ms cubic-bezier(0.34, 1.56, 0.64, 1)", "type": "transition" }
  },
  "zIndex": {
    "base":    { "value": 0,    "type": "number" },
    "above":   { "value": 10,   "type": "number" },
    "sticky":  { "value": 100,  "type": "number" },
    "overlay": { "value": 500,  "type": "number" },
    "modal":   { "value": 1000, "type": "number" },
    "toast":   { "value": 2000, "type": "number" }
  },
  "breakpoint": {
    "sm": { "value": "640px",  "type": "dimension" },
    "md": { "value": "768px",  "type": "dimension" },
    "lg": { "value": "1024px", "type": "dimension" },
    "xl": { "value": "1280px", "type": "dimension" },
    "2xl":{ "value": "1440px", "type": "dimension" }
  }
}
